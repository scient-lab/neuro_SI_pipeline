# .env.runpod.example — copy to .env.runpod and fill in.
#
# .env.runpod is gitignored (workstation secrets only).
# This template is committed so new operators know what's required.
#
# Usage:
#   cp .env.runpod.example .env.runpod
#   $EDITOR .env.runpod
#   ./scripts/launch_runpod.sh

# --- RunPod API access (REQUIRED) ----------------------------------------
# https://www.runpod.io/console/user/settings -> API Keys -> Create
RUNPOD_API_KEY=

# --- GitHub (REQUIRED for cloning private repo on the pod) ---------------
# Create a PAT with 'repo' scope: https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_REPO=scient-lab/neuro_SI_pipeline
GITHUB_BRANCH=dev

# --- LLM API keys --------------------------------------------------------
# REQUIRED for curriculum-generation phases (gemini-2.5-flash / gemini-2.0-flash)
GEMINI_API_KEY=
# REQUIRED to download gated HuggingFace models (Qwen, Mistral, etc.)
HF_TOKEN=

# --- Optional ------------------------------------------------------------
# Weights & Biases logging
WANDB_API_KEY=

# Default scenario when no CLI flag is passed
KGPL_SCENARIO=smoke

# Hardware overrides — leave blank to use configs/runpod_scenarios.yaml
RUNPOD_GPU_TYPE=
RUNPOD_CLOUD_TYPE=
RUNPOD_DISK_GB=
RUNPOD_NUM_GPUS=

# Where the repo is cloned on the pod (used by runpod_bootstrap.sh)
SI_HOME=/workspace/neuro_SI_pipeline

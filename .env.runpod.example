# .env.runpod.example — copy to .env.runpod and fill in.
#
# .env.runpod is gitignored (workstation secrets only).
# This template is committed so new operators know what's required.
#
# Usage:
#   cp .env.runpod.example .env.runpod
#   $EDITOR .env.runpod
#   ./scripts/launch_runpod.sh

# --- RunPod API access (REQUIRED) ----------------------------------------
# https://www.runpod.io/console/user/settings -> API Keys -> Create
RUNPOD_API_KEY=

# --- GitHub (REQUIRED for cloning private repo on the pod) ---------------
# Create a PAT with 'repo' scope: https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_REPO=scient-lab/neuro_SI_pipeline
GITHUB_BRANCH=dev

# --- LLM API keys --------------------------------------------------------
# REQUIRED for curriculum-generation phases (gemini-2.5-flash / gemini-2.0-flash)
GEMINI_API_KEY=
# REQUIRED for the curriculum pair-check (validate_qa_pair) with a hosted OpenAI reasoning
# model (o3-mini). Skip if curriculum.pair_check_base_url points at a local vLLM server.
OPENAI_API_KEY=
# REQUIRED to download gated HuggingFace models (Qwen, Mistral, etc.)
HF_TOKEN=

# --- AWS / S3 access (REQUIRED for pilot/paper; smoke uses local fixture)
# S3_URI is the program root. CORPUS_PATH is the same path under both S3
# and the local repo:
#   S3:    ${S3_URI}/${CORPUS_PATH}     (e.g. s3://enlibra/dss/corpus/neuroscience/source_txt/)
#   Local: ${REPO_ROOT}/${CORPUS_PATH}  (e.g. ./corpus/neuroscience/source_txt/)
#
# CORPUS_PATH can be a directory (preferred — all .txt inside become input
# documents) OR a single .txt file (cherry-pick one book). If unset,
# extract.sh defaults to corpus/${SI_DOMAIN}/source_txt/.
S3_URI=s3://enlibra/dss
CORPUS_PATH=corpus/neuroscience/source_txt
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# Periodic background output sync — pipeline.sh runs sync_outputs.sh every
# N seconds during execution (in addition to per-phase syncs). Catches
# intermediate training checkpoints; a pod crash at minute 175 leaves S3
# with state up to roughly minute (175 - N). Leave unset to disable.
# Minimum 10s; 300 (5 min) is a sensible default for hour-long phases.
S3_SYNC_INTERVAL_SEC=300
# Per-step CloudWatch Logs push (lib/common.sh::_cw_ship). One stream per
# (run_id, phase, step); leave unset to disable. Same AWS creds as S3.
# IAM user needs logs:CreateLogStream + logs:PutLogEvents on this group.
AWS_CLOUDWATCH_LOG_GROUP=/enlibra/dss/runs/pipeline

# --- Optional ------------------------------------------------------------
# Weights & Biases logging
WANDB_API_KEY=

# Default scenario when no CLI flag is passed
KGPL_SCENARIO=smoke

# Hardware overrides — leave blank to use configs/runpod_scenarios.yaml
RUNPOD_GPU_TYPE=
RUNPOD_CLOUD_TYPE=
RUNPOD_DISK_GB=
RUNPOD_NUM_GPUS=

# Where the repo is cloned on the pod (used by runpod_bootstrap.sh)
SI_HOME=/workspace/neuro_SI_pipeline

# --- RunPod Pod vLLM smoke (scripts/runpod/vllm_smoke.sh) ----------------
# Set these when you have a Pod running vLLM with --api-key, exposing the
# OpenAI-compatible API at /v1/chat/completions. Different mechanism from
# RUNPOD_API_KEY (which is for the RunPod control-plane API used by launch.sh).
# Leave blank if you only use Serverless endpoints — vllm_smoke.sh will error
# clearly when invoked.
VLLM_ENDPOINT_URL=
VLLM_API_KEY=

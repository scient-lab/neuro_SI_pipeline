__pycache__/
*.py[cod]
*.pyo
.env
.env.runpod
*.egg-info/
dist/
build/
.DS_Store
wandb/
wandb_logs/
*.log
.venv/
.venvs/

# Pipeline runtime artifacts — large, per-run, intentionally not committed.
outputs/

# Corpus content: ignore everything under per-domain source_* dirs
# (source_txt/, source_pdfs/, source_wikipedia/, source_pmc/, …). Smoke
# fixtures live in corpus/<domain>/smoke/ and stay committed.
corpus/*/source_*/

# SLURM stdout/stderr — keep the dir (via .gitkeep) but ignore generated logs.
slurm_logs/*.out
slurm_logs/*.err
!slurm_logs/.gitkeep

# Temporary files
tmp/
